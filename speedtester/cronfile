# Server selection is controlled via SPEEDTEST_SERVER_ID env var.
# If unset, speedtest auto-selects the best server.
# Example known servers:
#   3199  - NEXT LAYER GmbH, Vienna, Austria
#   4462  - Freisbach (auto-selected default)
#   31448 - Telekom Frankfurt
# https://crontab.guru/#0_*_*_*_*

0 * * * * root /usr/local/bin/run-speedtest
@reboot root /usr/local/bin/run-speedtest
